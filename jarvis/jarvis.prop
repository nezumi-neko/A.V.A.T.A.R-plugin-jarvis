{
    "modules": {
        "jarvis": {
            "version": "2.1",
            "name": "Jarvis",
            "active": true,
            "lettercd": "D",
            "ollamaPath": "C:/Users/VOTRE_USER/AppData/Local/Programs/Ollama/ollama_app.exe",
            "ramAlertThreshold": 90,
            "morningReport": true,
            "defaultClient": "Living room",
            "widget": { "display": true },
            "dashboard":    { "width": 420, "height": 280, "opacity": 1,    "devTools": false },
            "controlPanel": {                               "opacity": 0.97, "devTools": false },
            "nlpPosition": 4,
            "rules": {
                "interfacerun":    ["(run|launch|lance|open|start|execute) * (interface|rainmeter)"],
                "interfaceclose":  ["(close|quit|leave|farm|stop|exit) * (interface|rainmeter)"],
                "chromerun":       ["(run|launch|lance|open|start|execute) * chrome"],
                "chromeclose":     ["(close|quit|leave|farm|stop|exit) * chrome"],
                "gmailrun":        ["(run|launch|lance|open|start|execute) gmail"],
                "vlcrun":          ["(run|launch|lance|open|start|execute) * vlc"],
                "vlcclose":        ["(close|quit|leave|farm|stop|exit) * vlc"],
                "urlnetflix":      ["(run|launch|lance|open|start|execute) * netflix"],
                "urlyoutube":      ["(run|launch|lance|open|start|execute) * youtube"],
                "outlookrun":      ["(run|launch|lance|open|start|execute) * (email|emails|mail)"],
                "outlookclose":    ["(close|quit|leave|farm|stop|exit) * (email|emails|mail)"],
                "notepadrun":      ["(run|launch|lance|open|start|execute) * (text editor|notepad|éditeur)"],
                "notepadclose":    ["(close|quit|leave|farm|stop|exit) * (text editor|notepad|éditeur)"],
                "wordrun":         ["(run|launch|lance|open|start|execute) * (world|word)"],
                "wordclose":       ["(close|quit|leave|farm|stop|exit) * (world|word)"],
                "excelrun":        ["(run|launch|lance|open|start|execute) * excel"],
                "excelclose":      ["(close|quit|leave|farm|stop|exit) * excel"],
                "restartsystem":   ["restart * (pc|system|ordinateur)"],
                "shutdownsystem":  ["(shutdown|stop|éteins|éteindre) * (pc|computer|ordinateur)"],
                "logoutsystem":    ["(close|disconnect|déconnecte) * session"],
                "locksystem":      ["lock * (session|system|écran)", "verrouille * (session|écran)"],
                "hibernatesystem": ["(hibernate|hybernation|veille prolongée)"],
                "taskmanager":     ["(run|launch|open|start|ouvre) * task manager", "gestionnaire des tâches"],
                "commandline":     ["(run|launch|open|start|ouvre) * (command window|invite de commande)"],
                "powershellrun":   ["(run|launch|open|start|ouvre) * PowerShell"],
                "powershellclose": ["(close|quit|stop|exit|ferme|stoppe) * PowerShell"],
                "closeallwindows": ["close * all * windows", "ferme * toutes * (fenêtres|applications)"],
                "emptytash":       ["(empty|vide) * (trash|recycle|corbeille)"],
                "screensaver":     ["(run|launch|open|start|lance) * screen saver", "écran de veille"],
                "systemdiag":      ["diagnosis", "diagnostic système", "état * système", "performances système"],
                "volumeup":        ["(volume|son) * (up|plus|monte|augmente)", "monte le volume"],
                "volumedown":      ["(volume|son) * (down|moins|baisse|diminue)", "baisse le volume"],
                "volumemute":      ["(mute|sourdine|muet)", "coupe le son"],
                "brightnessup":    ["(brightness|luminosité) * (up|plus|monte|augmente)"],
                "brightnessdown":  ["(brightness|luminosité) * (down|moins|baisse|diminue)"],
                "screenshot":      ["(screenshot|capture|prends) * (screen|écran|capture)"],
                "notification":    ["(send|envoie) * notification *"],
                "folderun":        ["(run|launch|open|start|ouvre) * (explorer|explorateur)"],
                "newfolder":       ["{create} * new folder", "{crée} * nouveau dossier"],
                "calculatorrun":   ["(run|launch|open|start|ouvre) * calculator", "calculatrice"],
                "folderdownload":  ["(run|launch|open|start|ouvre) * (folder download|dossier téléchargements)"],
                "folderdiskc":     ["(run|launch|open|start|ouvre) * (folder disk C|disque C)"],
                "folderdesktop":   ["(run|launch|open|start|ouvre) * (folder desktop|bureau)"],
                "folderplugins":   ["(run|launch|open|start|ouvre) * plugin folder", "dossier plugins"],
                "folderavatar":    ["(run|launch|open|start|ouvre) * avatar folder", "dossier avatar"],
                "lecteurcdopen":   ["(run|launch|open|start|ouvre) * (disc player|lecteur cd)"],
                "lecteurcdclose":  ["(close|quit|leave|farm|stop|exit|ferme) * (disc player|lecteur cd)"],
                "dashboard":       ["(open|ouvre|affiche|lance|show) * dashboard", "tableau de bord"],
                "jarviscontrol":   ["(open|ouvre|affiche|lance|show) * (panneau|panel) jarvis", "panneau jarvis"],
                "restartclient":   ["restart * client", "redémarre le client"],
                "restartserver":   ["restart * server", "redémarre le serveur"],
                "restartall":      ["restart * (avatar|all|tout)", "redémarre avatar"],
                "searchinternet":  ["search *", "research *", "cherche *", "recherche *"],
                "checkollama":     ["check * (ia|ai|ollama)", "vérifie ollama", "démarre ollama"]
            }
        }
    },
    "cron": {
        "jarvis": { "name": "jarvis", "time": "0 */5 * * * *" }
    }
}
